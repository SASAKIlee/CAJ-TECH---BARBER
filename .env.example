# ==========================================
# SUPABASE (Obrigatório)
# ==========================================
# URL do seu projeto Supabase (encontre em: Settings > API)
VITE_SUPABASE_URL=https://xxxxx.supabase.co

# Chave pública (anon) do Supabase (encontre em: Settings > API)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJxxxxx

# ==========================================
# OPCIONAL - AFILIADOS
# ==========================================
# URL base para links de afiliados (padrão: URL atual do site)
# VITE_AFILIADO_BASE_URL=https://cajtech.net.br

# ==========================================
# NOTAS
# ==========================================
# 1. NUNCA commitar este arquivo com valores reais!
# 2. As variáveis VITE_ são expostas no frontend (seguro para chaves anon do Supabase)
# 3. Para variáveis secretas, use Edge Functions ou variáveis de ambiente do Vercel
# 4. Copie este arquivo para .env.local e preencha com seus valores
#
# Para configurar no Vercel:
# - Vá em Project Settings > Environment Variables
# - Adicione VITE_SUPABASE_URL e VITE_SUPABASE_PUBLISHABLE_KEY
