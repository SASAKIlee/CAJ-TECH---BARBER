                        {loja.diffDias !== undefined && loja.diffDias <= 0 && loja.ativo && <span className="bg-red-500/10 text-red-500 border border-red-500/20 text-[8px] font-black uppercase px-2 py-0.5 rounded-md">Fatura Vencida</span>}
