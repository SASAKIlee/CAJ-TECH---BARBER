                        </div>
                      </div>
                    </div>

                    {ag.observacao && (
                      <div className="mt-2 flex items-start gap-2 p-3 bg-yellow-500/10 border-l-2 border-yellow-500 rounded-lg">
                        <MessageCircle className="h-4 w-4 text-yellow-500 shrink-0 mt-0.5" />
