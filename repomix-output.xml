                        disabled={!!dismissing}
                        onClick={() => iniciarSaida(ag.id, "Cancelado")}
                        aria-label="Cancelar agendamento"
                      >
                        <X className="h-5 w-5 mr-1.5 stroke-[3px]" /> Cancelar
                      </MotionButton>
                    </div>
                  </Card>
                </motion.li>
              );
            })}
          </ul>
        )}
      </div>
    </div>
  );
}
