                    <div className="flex flex-wrap sm:flex-nowrap items-center gap-2 sm:gap-3 pt-4 border-t border-white/[0.08]">
                      <MotionButton
                        size="icon"
                        className={cn(
                          "h-12 w-12 rounded-xl shrink-0 border transition-all",
